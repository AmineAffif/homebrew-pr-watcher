#!/usr/bin/env bash
# Add a PR URL to the watch list without opening a dialog. Called by the
# "✨ Add from clipboard" menu bar entry (SwiftBar passes the URL as $1).
set -euo pipefail
umask 077

url="${1:-}"
[ -z "$url" ] && exit 0

if ! [[ "$url" =~ ^https://github\.com/[A-Za-z0-9._-]+/[A-Za-z0-9._-]+/pull/[0-9]+/?$ ]]; then
  osascript - "Not a GitHub PR URL: ${url}" <<'OSA' >/dev/null 2>&1 || true
on run argv
  display notification (item 1 of argv) with title "pr-watcher — skipped"
end run
OSA
  exit 1
fi
url="${url%/}"

CONFIG="${HOME}/.pr-watcher/config.json"
mkdir -p "$(dirname "$CONFIG")"
[ -f "$CONFIG" ] || echo '{"prs":[]}' > "$CONFIG"

tmp="$(mktemp)"
jq --arg u "$url" '.prs |= (. + [$u] | unique)' "$CONFIG" > "$tmp" && mv "$tmp" "$CONFIG"

pr-watcher --force >/dev/null 2>&1 || true

label="$(echo "$url" | sed -E 's|https://github.com/([^/]+)/([^/]+)/pull/([0-9]+).*|\2 #\3|')"
osascript - "$label" <<'OSA' >/dev/null 2>&1 || true
on run argv
  display notification (item 1 of argv) with title "pr-watcher — watching ✨"
end run
OSA
